# =============================================================================
# Buoy.Fish Coverage Mapper - Production Environment
# =============================================================================
# Used by: Phoenix prod config, systemd (buoy_mapper.service)
#
# Copy to .env on the production server and fill in values:
#   cp .env.production.example .env
#
# The systemd unit loads this file via EnvironmentFile=/home/ubuntu/map.buoy.fish/.env
# =============================================================================

# --- Server -------------------------------------------------------------------
MIX_ENV=prod
PORT=4001

# --- Phoenix (REQUIRED) ------------------------------------------------------
# Public hostname for URL generation and SSL
HOST=map.buoy.fish

# Session encryption key — generate with: mix phx.gen.secret
SECRET_KEY_BASE=<generate with: mix phx.gen.secret>

# --- PostgreSQL (REQUIRED) ----------------------------------------------------
# Full connection URI used by Ecto in config/prod.secret.exs
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Production uses peer auth (no password) with the ubuntu system user.
DATABASE_URL=postgresql://ubuntu@localhost:5432/buoy_mappers

# Connection pool size (tune based on server resources, default: 10)
POOL_SIZE=10

# --- Martin Tile Server -------------------------------------------------------
# Martin connects to the same PostgreSQL instance and serves vector tiles
# from the h3_res9 table. Configured in martin.service; listed here for
# reference and to keep all config in one place.
# MARTIN_DATABASE_URL=postgresql://ubuntu@localhost:5432/buoy_mappers
# MARTIN_PORT=3000

# --- SSL / TLS ----------------------------------------------------------------
# SSL is terminated at nginx (Let's Encrypt via certbot).
# Uncomment these only if terminating SSL at the Phoenix level:
# SSL_KEY_PATH=/etc/letsencrypt/live/map.buoy.fish/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/map.buoy.fish/fullchain.pem

# --- Logging ------------------------------------------------------------------
# LOG_LEVEL=info

# --- Admin API (REQUIRED) -----------------------------------------------------
# Shared-secret token for /api/v1/admin/* endpoints (e.g. coverage purge).
# MUST match the value set in app.buoy.fish's BUOY_MAPPERS_ADMIN_TOKEN.
# Generate with: openssl rand -hex 32
MAPPERS_ADMIN_TOKEN=<generate with: openssl rand -hex 32>

# --- Notes --------------------------------------------------------------------
# - nginx reverse-proxy config: deploy/nginx-map-buoy-fish.conf
# - systemd unit: deploy/buoy_mapper.service
# - Martin unit: deploy/martin.service
# - nginx proxies HTTPS :443 -> Phoenix :4001 and /tiles/ -> Martin :3000
# - Run database migrations before starting: mix ecto.migrate
# - Provision server from scratch: deploy/setup-mapper-infra.sh
