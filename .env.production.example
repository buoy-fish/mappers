# Buoy.Fish Coverage Mapper - Production Environment
# Copy to .env and fill in values

# PostgreSQL
DATABASE_URL=postgresql://ubuntu@localhost:5432/buoy_mappers

# Phoenix
HOST=map.buoy.fish
PORT=4001
SECRET_KEY_BASE=<generate with: mix phx.gen.secret>

# No MapLibre API key needed — uses open-source CARTO basemap
