# =============================================================================
# Buoy.Fish Coverage Mapper - Development Environment
# =============================================================================
# Used by: ./scripts/dev.sh, config/dev.exs
#
# Copy to .env.development and adjust for your local setup:
#   cp .env.dev.example .env.development
#
# All values below are sensible defaults for local development.
# =============================================================================

# --- Server -------------------------------------------------------------------
# Dev port (4002 avoids collision with app.buoy.fish on 4000)
PORT=4002

# --- PostgreSQL ---------------------------------------------------------------
# Individual components used by config/dev.exs
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mappers_dev

# --- Elixir / Phoenix --------------------------------------------------------
# MIX_ENV is set automatically by scripts; uncomment to force:
# MIX_ENV=dev

# Log level: debug | info | warn | error
# LOG_LEVEL=debug

# --- Admin API ---------------------------------------------------------------
# Shared-secret token for /api/v1/admin/* endpoints (e.g. coverage purge).
# Must match the value set in app.buoy.fish's BUOY_MAPPERS_ADMIN_TOKEN.
# Default in config/dev.exs is "dev-admin-token" if unset.
# MAPPERS_ADMIN_TOKEN=dev-admin-token

# --- app.buoy.fish upstream ---------------------------------------------------
# The "Show Gateways" layer fetches its gateway list from app.buoy.fish.
# Defaults to http://localhost:4000 (same-box dev setup).
# APP_BUOY_URL=http://localhost:4000

# --- Martin Tile Server (optional for local dev) -----------------------------
# Only needed if running Martin locally for vector tile development.
# Martin connects directly to PostgreSQL; set the URI here.
# MARTIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mappers_dev
# MARTIN_PORT=3000

# --- Node.js ------------------------------------------------------------------
# Uncomment if you hit OpenSSL errors with older Node versions:
# NODE_OPTIONS=--openssl-legacy-provider
