# Buoy.Fish Coverage Mapper — environment variables
#
# Copy to `.env` and fill in real values. Do NOT commit `.env` (gitignored).
# In production, this file lives at /home/ubuntu/map.buoy.fish/.env and is
# loaded by systemd via EnvironmentFile= in buoy_mapper.service.

# Phoenix
HOST=map.buoy.fish
PORT=4001
SECRET_KEY_BASE=
MIX_ENV=prod

# Admin coverage-purge endpoint shared secret. See
# lib/mappers_web/controllers/api/admin_controller.ex.
MAPPERS_ADMIN_TOKEN=

# Mapbox basemap (optional).
#
# When set, the frontend uses Mapbox's Maxar satellite + topography style
# (visual parity with upstream Helium Mappers). When unset, falls back to
# CartoCDN's open-source dark-matter style — no API key required, but no
# satellite imagery either.
#
# This is a *public* Mapbox token (pk.eyJ...) — designed to be exposed in
# the browser. Protect it via URL restriction in the Mapbox dashboard
# (https://account.mapbox.com/access-tokens/), restricted to *.buoy.fish.
#
# Token is inlined into the JS bundle at build time by esbuild (see
# assets/build.mjs). Changing the token requires a fresh `npm run deploy`.
MAPBOX_ACCESS_TOKEN=
