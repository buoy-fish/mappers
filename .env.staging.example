# =============================================================================
# Buoy.Fish Coverage Mapper - Staging Environment
# =============================================================================
# Used by: Phoenix prod config (MIX_ENV=prod with staging-specific values)
#
# Copy to .env on the staging server and fill in values:
#   cp .env.staging.example .env
#
# Staging mirrors production but uses a separate database and hostname.
# =============================================================================

# --- Server -------------------------------------------------------------------
MIX_ENV=prod
PORT=4001

# --- Phoenix ------------------------------------------------------------------
# Hostname for URL generation (e.g., staging subdomain)
HOST=staging-map.buoy.fish

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=<generate with: mix phx.gen.secret>

# --- PostgreSQL ---------------------------------------------------------------
# Full connection URI (required in prod config)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ubuntu@localhost:5432/buoy_mappers_staging

# Connection pool size (default: 10)
POOL_SIZE=10

# --- Martin Tile Server -------------------------------------------------------
# Martin connects to the same PostgreSQL instance and serves vector tiles.
# Configured in martin.service / martin CLI args; listed here for reference.
# MARTIN_DATABASE_URL=postgresql://ubuntu@localhost:5432/buoy_mappers_staging
# MARTIN_PORT=3000

# --- SSL / TLS ----------------------------------------------------------------
# SSL is handled by nginx + Let's Encrypt (certbot) on the server.
# Uncomment these only if terminating SSL at the Phoenix level:
# SSL_KEY_PATH=/etc/letsencrypt/live/staging-map.buoy.fish/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/staging-map.buoy.fish/fullchain.pem

# --- Logging ------------------------------------------------------------------
# LOG_LEVEL=info

# --- Notes --------------------------------------------------------------------
# - nginx proxies HTTPS :443 -> Phoenix :4001 and /tiles/ -> Martin :3000
# - Martin is managed by its own systemd unit (martin.service)
# - Run database migrations before starting: mix ecto.migrate
