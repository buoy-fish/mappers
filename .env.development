# Buoy.Fish Coverage Mapper - Development Environment
# Used by: ./scripts/dev.sh and config/dev.exs
#
# All values below are sensible defaults. Override as needed for your local setup.

# Dev server port (default 4002 to avoid colliding with app.buoy.fish on 4000)
PORT=4002

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mappers_dev
